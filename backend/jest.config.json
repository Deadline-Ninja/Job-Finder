{
  "testEnvironment": "node",
  "transform": {},
  "moduleFileExtensions": ["js", "jsx", "ts", "tsx", "json", "node"],
  "testMatch": ["**/__tests__/**/*.js", "**/?(*.)+(spec|test).js"],
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "verbose": true,
  "forceExit": true,
  "detectOpenHandles": true
}
